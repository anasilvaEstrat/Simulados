<script>
const SHEET_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vStxbC7N0Aax8R-8fbp69EyZ9vH3pWXSB7U6UeOAE88yed5EAiP5EmM-IiyuGAxMxNfbGwY7xx7gM1D/pub?gid=1188074275&single=true&output=csv';

let RAW=[], filtered=[], sortKey='', sortDir=1, page=0, ps=25;

// ---------- CSV PARSER ----------
function splitCSVLine(line) {
  const result = [];
  let cur = '', inQ = false;

  for (let i = 0; i < line.length; i++) {
    const c = line[i];

    if (c === '"') {
      if (inQ && line[i+1] === '"') {
        cur += '"';
        i++;
      } else {
        inQ = !inQ;
      }
    } else if (c === ',' && !inQ) {
      result.push(cur);
      cur = '';
    } else {
      cur += c;
    }
  }

  result.push(cur);
  return result;
}

function parseCSV(text) {
  const lines = text.trim().split(/\r?\n/);
  const headers = splitCSVLine(lines[0]);

  return lines.slice(1).map(line => {
    const vals = splitCSVLine(line);
    const obj = {};
    headers.forEach((h, i) => {
      obj[h.trim()] = (vals[i] || '').trim();
    });
    return obj;
  });
}

// ---------- LOAD ----------
async function loadData() {
  const res = await fetch(SHEET_URL + '&t=' + Date.now());
  const text = await res.text();

  RAW = parseCSV(text);
  applyFilter();
}

// ---------- DATE ----------
function parseDate(s) {
  if (!s) return new Date(2099,0,1);
  const [d,m,y] = s.split('/');
  return new Date(+y, +m-1, +d);
}

// ---------- FILTER ----------
function applyFilter() {
  filtered = [...RAW];

  if (sortKey) doSort();

  page = 0;
  render();
}

// ---------- SORT ----------
function sort(k) {
  sortDir = sortKey === k ? -sortDir : 1;
  sortKey = k;
  doSort();
  render();
}

function doSort() {
  filtered.sort((a, b) => {
    let va = a[sortKey] || '';
    let vb = b[sortKey] || '';

    if (sortKey === 'DATA')
      return sortDir * (parseDate(va) - parseDate(vb));

    if (sortKey === 'QUESTÕES')
      return sortDir * ((parseInt(va)||0) - (parseInt(vb)||0));

    return sortDir * va.localeCompare(vb, 'pt-BR');
  });
}

// ---------- RENDER ----------
function render() {
  const tbody = document.getElementById('tbody');

  tbody.innerHTML = filtered.map(r => `
    <tr>
      <td>${r['Status']}</td>
      <td>${r['Vertical']}</td>
      <td>${r['Tipo']}</td>
      <td>${r['Simulado']}</td>
      <td>${r['DATA']}</td>
      <td>${r['QUESTÕES']}</td>
      <td>${r['Responsável']}</td>
    </tr>
  `).join('');
}

// ---------- INIT ----------
loadData();
</script>
