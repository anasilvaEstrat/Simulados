<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Tabela de Simulados</title>

<style>
  body { font-family: Arial; padding: 20px; }
  table { border-collapse: collapse; width: 100%; }
  th, td { border: 1px solid #ccc; padding: 8px; }
  th { cursor: pointer; background: #f4f4f4; }
  tr:nth-child(even) { background: #fafafa; }
</style>
</head>

<body>

<h2>Simulados</h2>

<table>
  <thead>
    <tr>
      <th onclick="sort('Status')">Status</th>
      <th onclick="sort('Vertical')">Vertical</th>
      <th onclick="sort('Tipo')">Tipo</th>
      <th onclick="sort('Simulado')">Simulado</th>
      <th onclick="sort('DATA')">Data</th>
      <th onclick="sort('QUESTÕES')">Questões</th>
      <th onclick="sort('Responsável')">Responsável</th>
    </tr>
  </thead>

  <tbody id="tbody"></tbody>
</table>

<script>
const URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vStxbC7N0Aax8R-8fbp69EyZ9vH3pWXSB7U6UeOAE88yed5EAiP5EmM-IiyuGAxMxNfbGwY7xx7gM1D/pub?gid=1188074275&single=true&output=csv";

let dados = [];
let ordem = 1;
let colunaAtual = "";

// -------- CSV parser correto --------
function parseCSV(text) {
  const linhas = [];
  let linha = [];
  let valor = "";
  let dentroAspas = false;

  for (let i = 0; i < text.length; i++) {
    const c = text[i];

    if (c === '"') {
      dentroAspas = !dentroAspas;
    } 
    else if (c === ',' && !dentroAspas) {
      linha.push(valor);
      valor = "";
    } 
    else if (c === '\n' && !dentroAspas) {
      linha.push(valor);
      linhas.push(linha);
      linha = [];
      valor = "";
    } 
    else {
      valor += c;
    }
  }

  return linhas;
}

// -------- carregar dados --------
fetch(URL + "&t=" + new Date().getTime())
  .then(res => res.text())
  .then(text => {
    const tabela = parseCSV(text);

    const headers = tabela[0];

    dados = tabela.slice(1).map(linha => {
      let obj = {};
      headers.forEach((h, i) => {
        obj[h.trim()] = (linha[i] || "").trim();
      });
      return obj;
    });

    render();
  });

// -------- ordenar --------
function sort(col) {
  ordem = colunaAtual === col ? -ordem : 1;
  colunaAtual = col;

  dados.sort((a, b) => {

    let va = a[col] || "";
    let vb = b[col] || "";

    if (col === "DATA") {
      return ordem * (parseData(va) - parseData(vb));
    }

    if (col === "QUESTÕES") {
      return ordem * ((parseInt(va)||0) - (parseInt(vb)||0));
    }

    return ordem * va.localeCompare(vb, 'pt-BR');
  });

  render();
}

// -------- data --------
function parseData(s) {
  if (!s) return new Date(2099,0,1);
  const [d,m,y] = s.split("/");
  return new Date(y, m-1, d);
}

// -------- render --------
function render() {
  const tbody = document.getElementById("tbody");

  tbody.innerHTML = dados.map(r => `
    <tr>
      <td>${r['Status']}</td>
      <td>${r['Vertical']}</td>
      <td>${r['Tipo']}</td>
      <td>${r['Simulado']}</td>
      <td>${r['DATA']}</td>
      <td>${r['QUESTÕES']}</td>
      <td>${r['Responsável']}</td>
    </tr>
  `).join("");
}
</script>

</body>
</html>
