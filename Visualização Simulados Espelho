<table border="1" id="tabela"></table>

<script>
fetch("https://docs.google.com/spreadsheets/d/e/2PACX-1vStxbC7N0Aax8R-8fbp69EyZ9vH3pWXSB7U6UeOAE88yed5EAiP5EmM-IiyuGAxMxNfbGwY7xx7gM1D/pub?gid=1188074275&single=true&output=csv")
  .then(res => res.text())
  .then(text => {
    const linhas = text.split("\n").filter(l => l.trim());

    const tabela = linhas.map(linha => {
      // regex que respeita aspas
      const cols = linha.match(/(".*?"|[^",\t]+)(?=\s*,|\s*\t|$)/g);

      return cols.map(c => c.replace(/^"|"$/g, "").trim());
    });

    let html = "";

    tabela.forEach((linha, i) => {
      html += "<tr>";
      linha.forEach(col => {
        html += i === 0
          ? `<th>${col}</th>`
          : `<td>${col}</td>`;
      });
      html += "</tr>";
    });

    document.getElementById("tabela").innerHTML = html;
  });
</script>
