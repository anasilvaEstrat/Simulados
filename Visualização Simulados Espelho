<table border="1" id="tabela"></table>

<script>
fetch("https://docs.google.com/spreadsheets/d/e/2PACX-1vStxbC7N0Aax8R-8fbp69EyZ9vH3pWXSB7U6UeOAE88yed5EAiP5EmM-IiyuGAxMxNfbGwY7xx7gM1D/pub?gid=1188074275&single=true&output=csv")
  .then(res => res.text())
  .then(text => {

    function parseCSV(str) {
      const linhas = [];
      let linha = [];
      let valor = "";
      let dentroAspas = false;

      for (let i = 0; i < str.length; i++) {
        const char = str[i];

        if (char === '"') {
          dentroAspas = !dentroAspas;
        } 
        else if (char === ',' && !dentroAspas) {
          linha.push(valor);
          valor = "";
        } 
        else if (char === '\n' && !dentroAspas) {
          linha.push(valor);
          linhas.push(linha);
          linha = [];
          valor = "";
        } 
        else {
          valor += char;
        }
      }

      return linhas;
    }

    const tabela = parseCSV(text);

    let html = "";

    tabela.forEach((linha, i) => {
      if (!linha.length) return;

      html += "<tr>";
      linha.forEach(col => {
        html += i === 0
          ? `<th>${col}</th>`
          : `<td>${col}</td>`;
      });
      html += "</tr>";
    });

    document.getElementById("tabela").innerHTML = html;
  });
</script>
